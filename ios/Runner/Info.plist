<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.excellisit.cuapp.refresh</string>
		<string>com.excellisit.cuapp.process</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>CU</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>cu_app</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationCategoryType</key>
	<string></string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>MinimumOSVersion</key>
	<string>15.0</string>
	<key>NSCameraUsageDescription</key>
	<string>We need access to your camera for video calls</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>$(PRODUCT_NAME) Microphone Usage!</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Choose photo from Library to send in a group</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>This app needs permission to save recordings and media to your photo library.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>This app needs access to your calendar to sync meetings and add events.</string>
	<key>NSPushNotificationUsageDescription</key>
	<string>This app uses notifications to keep you updated.</string>
	<key>NSUserNotificationAlertStyle</key>
	<string>alert</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<!-- Calling setup start -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
		<string>fetch</string>
		<string>voip</string>
		<string>audio</string>
	</array>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>This app needs access to Bluetooth for calls</string>
	<!-- Calling setup end -->

	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations - 2</key>
	<string>UseGalleryImageForProfileImageUpload</string>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>com.apple.developer.pushkit.unrestricted-voip</key>
	<true/>
	<key>com.apple.developer.voip</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>

		<!-- allow the app's view to be used as Picture‑in‑Picture target -->
	<key>UISupportsPictureInPicture</key>
	<true/>
	<key>NSAllowsArbitraryLoads</key>
    <true/>

	

</dict>
</plist>
